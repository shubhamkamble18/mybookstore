# MyBookstore Environment Variables

# ========================================
# FRONTEND (.env for Vite)
# ========================================
# Place these in frontend/.env
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_KEY
VITE_BACKEND_URL=http://localhost:5000

# ========================================
# BACKEND (.env for Flask)
# ========================================
# Place these in backend/.env
FLASK_ENV=development
FLASK_DEBUG=True

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mybookstore

# Stripe Keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Firebase Keys
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# Flask Security
SECRET_KEY=your_secret_key_here

# Redis (optional)
REDIS_URL=redis://localhost:6379

# ========================================
# Development Database Setup
# ========================================
# PostgreSQL (recommended for production)
# or SQLite for local development
