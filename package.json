{
  "name": "mybookstore",
  "version": "1.0.0",
  "description": "MyBookstore - Full-stack book e-commerce application",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && python app.py",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "start": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && npm install --workspace=frontend && pip install -r backend/requirements.txt"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "bookstore",
    "e-commerce",
    "react",
    "flask",
    "stripe"
  ],
  "author": "Your Name",
  "license": "MIT"
}
